<Window x:Class="FanControlUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Universal Fan Hub" Height="500" Width="450"
        Background="#1E1E1E" Foreground="White">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#2A2A2A" CornerRadius="5" Padding="15" Margin="0,0,0,15" Grid.Row="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="CPU Max Core Temp:" FontSize="12" Foreground="#AAAAAA"/>
                    <TextBlock x:Name="CpuTempText" Text="-- °C" FontSize="26" FontWeight="Bold" Foreground="#FF5A5A" Margin="0,5,0,0"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1">
                    <TextBlock Text="GPU Core Temp:" FontSize="12" Foreground="#AAAAAA"/>
                    <TextBlock x:Name="GpuTempText" Text="-- °C" FontSize="26" FontWeight="Bold" Foreground="#5AFF5A" Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ControllersList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#2A2A2A" CornerRadius="5" Padding="15" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                                
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Content="AUTO Curve" IsChecked="{Binding IsAuto}" Foreground="White" VerticalAlignment="Center" Grid.Column="0"/>
                                    <TextBlock Text="{Binding SpeedText}" Foreground="#5A9DFF" FontSize="18" FontWeight="Bold" HorizontalAlignment="Right" Grid.Column="1"/>
                                </Grid>

                                <Slider Minimum="0" Maximum="100" Value="{Binding TargetSpeed}" IsEnabled="{Binding IsManual}" TickFrequency="1" IsSnapToTickEnabled="True" AutoToolTipPlacement="TopLeft"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>